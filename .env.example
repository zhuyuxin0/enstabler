# 0G Galileo testnet
OG_PRIVATE_KEY=
OG_WALLET_ADDRESS=
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# 0G Compute auth is wallet-based (uses OG_PRIVATE_KEY above).
# Provider must be funded once: `0g-compute-cli deposit --amount 10`
#                               `0g-compute-cli transfer-fund --provider <addr> --amount 1`

# Deployed contract addresses (filled in after deploy)
FLOW_RISK_ORACLE_ADDRESS=
AGENT_NFT_ADDRESS=

# Data sources (mainnet reads, no gas)
BITQUERY_API_KEY=
ALCHEMY_API_KEY=
ALCHEMY_WS_URL=

# KeeperHub
KEEPERHUB_API_KEY=
# Find your KeeperHub Turnkey wallet address in the dashboard (Settings → Wallet).
# Same address works on mainnet AND Sepolia (Turnkey is chain-agnostic).
KEEPERHUB_WALLET_ADDRESS=
# KeeperHub MCP workflow id to execute on every critical (risk=3) classification.
# Use any workflow id visible to your org (default-created ones work fine).
KEEPERHUB_WORKFLOW_ID=

# Swap execution network: "sepolia" (default, free) or "ethereum" (real money).
# When the depeg trigger fires the agent sells USDC for the configured TOKEN_OUT.
#   sepolia default: USDC → WETH  (the V2 USDC↔WETH pool actually has liquidity)
#   ethereum default: USDC → USDT (production — needs real funding)
# Sepolia funding (free):
#   ETH : sepoliafaucet.com (~0.05 ETH for gas; you only need ETH, not WETH)
#   USDC: faucet.circle.com (Circle's official Sepolia USDC)
KEEPERHUB_NETWORK=sepolia
# Optional address overrides (defaults are sane per network — see agent/swap.py)
SWAP_USDC_ADDRESS=
SWAP_TOKEN_OUT_ADDRESS=
SWAP_TOKEN_OUT_SYMBOL=
SWAP_ROUTER_ADDRESS=
# Min-out floor in raw token units; 0 (any output) is fine on testnet,
# set a real number on mainnet to protect against sandwich attacks.
SWAP_MIN_OUT_RAW=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Circle (no key needed)
CIRCLE_IRIS_API_URL=https://iris-api.circle.com
