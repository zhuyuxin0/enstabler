# 0G Galileo testnet
OG_PRIVATE_KEY=
OG_WALLET_ADDRESS=
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# 0G Compute auth is wallet-based (uses OG_PRIVATE_KEY above).
# Provider must be funded once: `0g-compute-cli deposit --amount 10`
#                               `0g-compute-cli transfer-fund --provider <addr> --amount 1`

# Deployed contract addresses (filled in after deploy)
FLOW_RISK_ORACLE_ADDRESS=

# Data sources (mainnet reads, no gas)
BITQUERY_API_KEY=
ALCHEMY_API_KEY=
ALCHEMY_WS_URL=

# KeeperHub
KEEPERHUB_API_KEY=
# Find your KeeperHub Turnkey wallet address in the dashboard (Settings → Wallet),
# then send ETH (gas), USDC, and USDT to it before enabling depeg-triggered swaps.
KEEPERHUB_WALLET_ADDRESS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Circle (no key needed)
CIRCLE_IRIS_API_URL=https://iris-api.circle.com
